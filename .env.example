APP_ENV=debug
APP_PORT=8080
APP_TIMEOUT=100s
APP_CLIENT_URLS=http://localhost:5173
APP_REGISTER_VERIFICATION_URL=http://localhost:5173/auth/verify-registration
APP_RESET_PASSWORD_URL=http://localhost:5173/auth/reset-password

AUTH_SECRET_KEY=thisissecret
AUTH_TOKEN_DURATION=12h
AUTH_ISSUER=stora
AUTH_HASH_COST=10
AUTH_STATE_STORE=inmemory

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stora
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

MAIL_SENDER_MAIL=test@mail.com
MAIL_SENDER_NAME=Stora
MAIL_API_KEY=your-api-key

OAUTH_GOOGLE_CLIENT_ID=xxx-xxx.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-xxx
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:5173/auth/google/callback

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp-gateway-prod-ap-southeast-2.grafana.net/otlp"
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic xxx"
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
OTEL_EXPORTER_OTLP_INSECURE=false
OTEL_SERVICE_NAME=stora
OTEL_SERVICE_INSTANCE_ID=local

VALKEY_ADDR=localhost:6379
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_ENABLE_TLS=false

GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/stora
GOOSE_MIGRATION_DIR=./internal/adapters/db/postgres/migrations
